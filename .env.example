# Optional: enables the real LLM agent engine (persona building + agent
# conversations via Claude). Without it the app uses the scripted engine.
ANTHROPIC_API_KEY=
# Optional override; defaults to claude-sonnet-4-6
ANTHROPIC_MODEL=

# Production launch basics
APP_PUBLIC_ORIGIN=
REDSTRING_DB_FILE=
ADMIN_TOKEN=
CAPACITOR_SERVER_URL=

# Optional: real Spotify OAuth for the onboarding connector. Create an app at
# https://developer.spotify.com/dashboard and add
# <your-origin>/api/connect/spotify/callback as a redirect URI.
# Without these the Spotify card falls back to mock data.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Only needed if your public origin differs from the request origin (proxies):
SPOTIFY_REDIRECT_URI=

# Provider seams for production swaps. Empty values keep local mock behavior.
RESEND_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
PUSH_PROVIDER=
PUSH_API_KEY=
PLACES_PROVIDER=
PLACES_API_KEY=
CALENDAR_PROVIDER=
CALENDAR_CLIENT_ID=
CALENDAR_CLIENT_SECRET=
